// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              Int      @id @default(autoincrement())
  username        String   @unique
  password        String
  role            String   @default("OPERATOR") // "ADMIN" or "OPERATOR"
  recoveryKeyHash String?  // Mã hash dùng cho Admin quên mật khẩu
  createdAt       DateTime @default(now())
}

model AudioFile {
  id           Int            @id @default(autoincrement())
  name         String
  filename     String         @unique
  path         String
  duration     Int?           // in seconds
  createdAt    DateTime       @default(now())
  playlistItems PlaylistItem[]
  bells        BellConfig[]
  periods      Period[]
}

model Playlist {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  volume      Float          @default(1.0)
  createdAt   DateTime       @default(now())
  items       PlaylistItem[]
  schedules   Schedule[]
}

model PlaylistItem {
  id          Int       @id @default(autoincrement())
  playlistId  Int
  audioFileId Int
  order       Int       @default(0)
  
  playlist    Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  audioFile   AudioFile @relation(fields: [audioFileId], references: [id], onDelete: Cascade)
  
  @@unique([playlistId, audioFileId, order])
}

model Schedule {
  id          Int      @id @default(autoincrement())
  name        String
  startTime   String   // format HH:mm
  endTime     String   // format HH:mm
  playlistId  Int
  isActive    Boolean  @default(true)
  daysOfWeek  String   // e.g., "1,2,3,4,5" for Mon-Fri
  
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

model Department {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  color       String?      @default("#863bff")
  bells       BellConfig[]
  periods     Period[]
}

model BellConfig {
  id           Int        @id @default(autoincrement())
  name         String?    // e.g. "Tiết 1"
  departmentId Int
  time         String     // format HH:mm:ss
  audioFileId  Int
  volume       Float      @default(1.0)
  isActive     Boolean    @default(true)
  daysOfWeek   String     // e.g., "1,2,3,4,5"
  
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  audioFile    AudioFile  @relation(fields: [audioFileId], references: [id], onDelete: Restrict)
}

model Period {
  id           Int        @id @default(autoincrement())
  name         String     // "Tiết 1", "Ca sáng"
  departmentId Int
  startTime    String     // format HH:mm:ss (Giờ vào)
  endTime      String     // format HH:mm:ss (Giờ ra)
  audioFileId  Int
  volume       Float      @default(1.0)
  isActive     Boolean    @default(true)
  daysOfWeek   String     // e.g., "1,2,3,4,5" for Mon-Fri

  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  audioFile    AudioFile  @relation(fields: [audioFileId], references: [id], onDelete: Restrict)
}

model Device {
  id          String   @id // Client UUID
  name        String
  isApproved  Boolean  @default(false)
  ipAddress   String?
  browserInfo String?
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())
}

model DeviceFingerprint {
  id           Int       @id @default(autoincrement())
  ipAddress    String
  browserInfo  String
  rejectCount  Int       @default(0)
  blockLevel   Int       @default(0)
  blockedUntil DateTime?
  
  @@unique([ipAddress, browserInfo])
}
